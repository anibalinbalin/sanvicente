# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.js

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# local env files
.env.local
.env.development
.env.test
.env.production

# vercel
.vercel

# typescript
*.tsbuildinfo

# Seo stuff created at build time
public/sitemap.xml
public/sitemap-?.xml
public/robots.txt

# No need to track cached files into source control
**/*.db

# Generated
schema.generated.graphql
src/graphql/generated/

.contentlayer

# Panda
ds.env.local
.env.local
.env.local
.env.local

# Large media files
public/assets/**/*.webp
public/assets/**/*.jpg
public/assets/**/*.png
public/assets/**/*.gif

# IDE and Editor files
.vscode/
.idea/
*.swp
*.swo

# Build artifacts
.cache/
dist/
build/
.next/
out/

# Type definition files
ds/types/
*.d.ts

# Logs
*.log

# Large media files
*.png
*.jpg
*.jpeg
*.gif
*.mp4
*.mov
*.avi
*.webm
*.ogg
*.m4a
